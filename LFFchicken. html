<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Poppins&display=swap" rel="stylesheet">

<title>LFF Chicken</title>

<style>
body{
    margin:0;
    font-family:Poppins;
    overflow:hidden;
}

/* HEADER (TOP SHOP NAME) */
.header{
    height:60px;
    background:#d62828;
    color:white;
    display:flex;
    align-items:center;
    justify-content:center;
    font-family:'Bebas Neue';
    font-size:32px;
}

/* PAGE */
.page{
    display:none;
    height:100vh;
}
.active{
    display:block;
}

/* LOGIN PAGE */
.login{
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    height:calc(100vh - 60px);
    background:url('https://images.unsplash.com/photo-1600891964599-f61ba0e24092') center/cover;
}

.login-box{
    background:white;
    padding:25px;
    border-radius:10px;
    width:250px;
    text-align:center;
}

input,button{
    width:100%;
    padding:10px;
    margin-top:10px;
    border:none;
    border-radius:5px;
}

button{
    background:#d62828;
    color:white;
    transition:0.2s;
}

button:active{
    background:white;
    color:#d62828;
    border:1px solid #d62828;
}

/* MENU */
.container{
    height:calc(100vh - 60px);
    overflow:auto;
    padding:10px;
}

.menu-grid{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:10px;
}

.card{
    background:white;
    border-radius:10px;
    text-align:center;
    padding:8px;
}

/* EQUAL IMAGE SIZE */
.card img{
    width:100%;
    height:300px;
    object-fit:cover;
    border-radius:8px;
    box-shadow:0 2px 8px
rgba(0,0,0,0.2);
}

/* CENTER */
.center{
    text-align:center;
    padding:20px;
}

.qr img{
    width:150px;
}
/* ITEM ROW BOX */
.item-row{
    background:white;
    padding:10px;
    border-radius:8px;
    margin:10px 0;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

/* FOOD NAME */
.item-name{
    font-weight:600;
    color:black;
}

/* BUTTON GROUP */
.qty-box{
    display:flex;
    align-items:center;
    gap:5px;
}

/* SMALL BUTTONS */
.qty-btn{
    width:28px;
    height:28px;
    font-size:16px;
    padding:0;
    display:flex;
    align-items:center;
    justify-content:center;
    background:#d62828;
    color:white;
    border:none;
    border-radius:4px;
    cursor:pointer;
}

/* REMOVE BUTTON */
.remove-btn{
    background:black;
    color:white;
    padding:5px 8px;
    font-size:12px;
}
</style>
</head>

<body>

<!-- LOGIN PAGE -->
<div class="page active" id="page1">
<div class="header">🍗 LFF Chicken</div>

<div class="login">
<div class="login-box">
<input type="text" id="phone" placeholder="Enter Phone Number">
<button onclick="goMenu()">Next</button>
</div>
</div>
</div>

<!-- MENU PAGE -->
<div class="page" id="page2">
<div class="header">🍗 LFF Chicken</div>

<div class="container">
<div class="menu-grid">

<div class="card">
<img src="https://images.unsplash.com/photo-1568901346375-23c9450c58cd">
<p>Burger ₹120</p>
<button onclick="addItem('Burger',120)">Add</button>
</div>

<div class="card">
<img src="https://img.freepik.com/premium-photo/ideal-image-indian-tandoori-chicken-with-copy-space_641503-86596.jpg">
<p>Tandoori Chicken ₹150</p>
<button onclick="addItem('Chicken',150)">Add</button>
</div>

<div class="card">
<img src="https://linacorner.com/wp-content/uploads/2025/08/grilled-chicken-recipe.png">
<p>Grill Chicken ₹100</p>
<button onclick="addItem('Fries',80)">Add</button>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1513104890138-7c749659a591">
<p>Pizza ₹200</p>
<button onclick="addItem('Pizza',200)">Add</button>
</div>

<div class="card">
<img src="https://img.freepik.com/premium-photo/golden-crispy-fried-chicken-served-platter-enticingly-crunchy-delicious_1229213-7361.jpg">
<p>Crispy Fried Chicken ₹180</p>
<button onclick="addItem('Pepsi',50)">Add</button>
</div>

<div class="card">
<img src="https://c8.alamy.com/comp/3AMK84F/poznan-pol-aug-7-2024-cans-of-pepsi-and-coke-popular-carbonated-soft-drinks-3AMK84F.jpg">
<p>Soft Drinks ₹50</p>
<button onclick="addItem('Coca Cola',50)">Add</button>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1613478223719-2ab802602423">
<p>Fresh juice ₹80</p>
<button onclick="addItem('Sprite',50)">Add</button>
</div>

<div class="card">
<img src="https://images3.alphacoders.com/868/thumb-1920-868525.jpg">
<p>Sandwich ₹120</p>
<button onclick="addItem('Fanta',50)">Add</button>
</div>

<div class="card">
<img src="https://media.istockphoto.com/id/1364914067/photo/homemade-chicken-nuggets-and-sauces-with-copy-space.jpg?s=612x612&w=0&k=20&c=tZxYOJdXj9Cd4u_fSwJ01uqzd3hR-ShVzTijQuY3zsM=">
<p>Nuggets ₹100</p>
<button onclick="addItem('Nuggets',130)">Add</button>
</div>

<div class="card">
<img src="https://img.freepik.com/premium-photo/crispy-fried-chicken-burger-with-fries-chicken-nuggets_1335264-276.jpg?w=2000"> 
<p>Combo ₹300</p>
<button onclick="addItem('Combo',250)">Add</button>
</div>

</div>

<br>
<button onclick="goSummary()">Next</button>
</div>
</div>

<!-- SUMMARY PAGE -->
<div class="page" id="page3">
<div class="header">🍗 LFF Chicken</div>

<div class="container">
<h3>Order Summary</h3>

<ul id="orderList"></ul>
<h3>Total ₹<span id="total"></span></h3>

<div class="center qr">
<img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=Payment">
</div>

<button onclick="payNow()">Pay</button>
</div>
</div>

<!-- SUCCESS PAGE -->
<div class="page" id="page4">
<div class="header">🍗 LFF Chicken</div>

<div class="center">
<h2>✅ Order Received</h2>
<p>Your order will be delivered in 10 minutes</p>
</div>
</div>

<script>
let cart={};
let total=0;

function goMenu(){
let phone=document.getElementById("phone").value;
if(phone==""){alert("Enter phone number");return;}
showPage(2);
}

function addItem(name,price){
if(cart[name]){
cart[name].qty++;
} else{
cart[name]={price:price,qty:1};
}
}
function removeOne(name){
    if(cart[name]){
        cart[name].qty--;
        if(cart[name].qty <= 0){
            delete cart[name];
        }
    }
    goSummary();
}

function removeItem(name){
    delete cart[name];
    goSummary();
}

function showPage(p){
    document.querySelectorAll(".page").forEach(pg=>pg.classList.remove("active"));
    document.getElementById("page"+p).classList.add("active");
}
function goSummary(){
    let list = document.getElementById("orderList");
    let total = 0;
    list.innerHTML = "";

    if(Object.keys(cart).length === 0){
        list.innerHTML = "<p style='color:white;'>Your cart is empty</p>";
        document.getElementById("total").innerText = "0";
        showPage(3);
        return;
    }

    for(let item in cart){
        let qty = cart[item].qty;
        let price = cart[item].price;
        let subtotal = qty * price;
        total += subtotal;

        let li = document.createElement("li");

        li.innerHTML = `
        <div class="item-row">
            
            <div class="item-name">
                ${item} <br> ₹${price} x ${qty} = ₹${subtotal}
            </div>

            <div class="qty-box">
                <button class="qty-btn" onclick="removeOne('${item}')">-</button>
                <span>${qty}</span>
                <button class="qty-btn" onclick="addItem('${item}', ${price})">+</button>
                <button class="remove-btn" onclick="removeItem('${item}')">x</button>
            </div>

        </div>
        `;

        list.appendChild(li);
    }

    document.getElementById("total").innerText = total;
    showPage(3);
}

function payNow(){
showPage(4);
}
</script>
</body>
</html>